# Copy to .env.local and fill in. See README.md -> Local development.

# Postgres connection string (Neon). The @neondatabase/serverless driver speaks HTTP,
# so this must be a Neon endpoint (a cloud branch, or the Neon Local proxy) — a bare
# postgres://localhost will NOT work with this driver.
POSTGRES_URL=

# Auth.js (next-auth v5) secret, used to encrypt JWT sessions and email tokens.
# Required — the app will not start without it. Generate a random value with: openssl rand -base64 33
AUTH_SECRET=

# Resend API key, used to send magic-link sign-in emails (https://resend.com).
# Note: the sender configured in auth.ts must be a verified Resend domain, or emails won't send.
AUTH_RESEND_KEY=
