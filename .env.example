# Copy to .env.local and fill in. See README.md -> Local development.

# Postgres connection string (Neon). The @neondatabase/serverless driver speaks HTTP,
# so this must be a Neon endpoint (a cloud branch, or the Neon Local proxy) — a bare
# postgres://localhost will NOT work with this driver.
POSTGRES_URL=

# Auth.js (next-auth v5) secret, used to encrypt JWT sessions and email tokens.
# Required — the app will not start without it. Generate a random value with: openssl rand -base64 33
AUTH_SECRET=

# Resend API key, used to send magic-link sign-in emails (https://resend.com).
AUTH_RESEND_KEY=

# "From" address for magic-link emails. Optional — defaults to auth@keepalink.com
# (which must be a domain verified in your Resend account). For local dev,
# onboarding@resend.dev is Resend's no-setup test sender: no domain verification
# needed, but it only delivers to your own Resend account email.
AUTH_EMAIL_FROM=onboarding@resend.dev

# Better Auth (migration in progress). Optional in dev: BETTER_AUTH_SECRET falls back
# to AUTH_SECRET when unset, and BETTER_AUTH_URL defaults to http://localhost:3000.
# Set both explicitly in production.
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=https://your-domain.example
